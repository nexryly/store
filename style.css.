*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:Arial,sans-serif;
}

body{
    background:#0b0b12;
    color:#fff;
}

header{
    background:linear-gradient(135deg,#2d0b52,#4b0082,#7b2cff);
    padding:70px 20px;
    text-align:center;
    box-shadow:0 0 30px rgba(123,44,255,.4);
}

header h1{
    font-size:42px;
    margin-bottom:10px;
}

header p{
    color:#cfcfcf;
}

.container{
    width:90%;
    max-width:1200px;
    margin:auto;
    padding:40px 0;
}

.box{
    background:rgba(255,255,255,.05);
    border:1px solid rgba(255,255,255,.1);
    backdrop-filter:blur(12px);
    border-radius:20px;
    padding:25px;
    margin-bottom:25px;
    box-shadow:0 0 20px rgba(123,44,255,.25);
}

h2{
    color:#c77dff;
    margin-bottom:20px;
}

.btn{
    display:inline-block;
    padding:14px 28px;
    border-radius:12px;
    text-decoration:none;
    color:#fff;
    font-weight:bold;
    background:linear-gradient(90deg,#7b2cff,#b026ff);
    transition:.3s;
}

.btn:hover{
    transform:scale(1.05);
    box-shadow:0 0 20px #7b2cff;
}

footer{
    text-align:center;
    padding:25px;
    background:#11111a;
    border-top:1px solid #7b2cff;
    color:#aaa;
}
